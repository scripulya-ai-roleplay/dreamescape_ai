# --- Application ---
DEBUG=false
HOST=0.0.0.0
PORT=8000

# --- Database ---
DATABASE_URL=postgresql+asyncpg://user:password@postgres:5432/dbname

# --- JWT ---
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_PUBLIC_KEY=
JWT_ALGORITHM=HS256

# --- LLM provider keys (legacy direct providers; unused now that LLM calls are delegated to scripulya_agent) ---
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# --- RabbitMQ / scripulya_agent integration ---
# The backend publishes LLMRequest to llm.agent.request and consumes LLMResult from
# llm.agent.result. scripulya_agent must connect to the same RABBIT_URL broker.
# Set LLM_AGENT_ENABLED=false to run without RabbitMQ/scripulya_agent (local docker):
# a mock client is used and the broker is never started. Use the testing_mock model
# for a fully offline chat; real models drop their requests in that mode.
LLM_AGENT_ENABLED=true
RABBIT_URL=amqp://guest:guest@rabbitmq:5672/
LLM_AGENT_REQUEST_QUEUE=llm.agent.request
LLM_AGENT_RESULT_QUEUE=llm.agent.result
LLM_AGENT_TIMEOUT=60

# --- Generation defaults ---
SYSTEM_PROMPT=You are a helpful assistant.

# --- Object storage (MinIO / S3) for media assets ---
# MINIO_INTERNAL_ENDPOINT: host the backend uses for data ops (in-network service name).
# MINIO_PUBLIC_ENDPOINT: host embedded in the URLs handed to clients — must be
#   reachable FROM the client. compose: localhost:9000; k8s NodePort: localhost:30900;
#   prod: real DNS. A wrong value makes every image URL 404 (presigned Host mismatch).
MINIO_INTERNAL_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
# Same values as the MinIO server's MINIO_ROOT_USER / MINIO_ROOT_PASSWORD; the app
# uses them as its S3 access key / secret.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_PUBLIC=scripulya-public
MINIO_BUCKET_PRIVATE=scripulya-private
MINIO_PRESIGN_EXPIRY_SECONDS=900
MEDIA_MAX_UPLOAD_BYTES=10485760
